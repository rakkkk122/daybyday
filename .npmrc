# .npmrc — Konfigurasi npm untuk Daily Life Manager
# Hanya config yang didukung npm modern (config lama sudah dihapus)

# Paksa npm simpan exact version (tidak caret ^)
save-exact=true

# Reduce noise
fund=false
audit=false

# Timeout lebih lama untuk koneksi lambat di HP
fetch-timeout=300000
fetch-retries=5
