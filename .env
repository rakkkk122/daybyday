DATABASE_URL=file:/home/z/my-project/db/custom.db
# ---- OLLAMA (RECOMMENDED — offline, gratis, no API key) ----
# Untuk fitur: Perbaiki Grammar, Translate, AI Assistant (fallback)
#
# Cara setup di Termux HP:
#   bash setup-ollama.sh  (auto-install + download model)
#
# Atau pakai Ollama di PC (HP akses via WiFi):
#   1. Install Ollama di PC: https://ollama.com
#   2. Set OLLAMA_URL=http://IP-PC-ANDA:11434 di bawah
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b
